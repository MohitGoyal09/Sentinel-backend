# ============================================
# AlgoQuest Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] will break the app if missing.

# ---------- Database ----------
# [REQUIRED] PostgreSQL connection string (Supabase or local)
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# ---------- Supabase ----------
# [REQUIRED] Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase anon/public key (for client-side auth)
SUPABASE_KEY=your_supabase_anon_key

# [REQUIRED] Supabase service role key (for admin operations)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ---------- Security ----------
# [REQUIRED] Random salt for hashing user identities (any random string, 32+ chars)
VAULT_SALT=generate-a-random-string-here

# [REQUIRED] Fernet encryption key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate-a-fernet-key-here

# ---------- LLM / AI ----------
# LLM Configuration (Portkey AI Gateway)
# Get your Portkey API key at https://portkey.ai
# Create virtual keys in the Portkey dashboard pointing to your LLM providers
PORTKEY_API_KEY=your-portkey-api-key
PORTKEY_VIRTUAL_KEY=your-primary-virtual-key
PORTKEY_FALLBACK_VIRTUAL_KEY=your-fallback-virtual-key
LLM_MODEL=gemini-2.0-flash
LLM_FALLBACK_MODEL=gemini-1.5-flash

# OpenAI (for direct use or via Portkey virtual key)
OPENAI_API_KEY=

# ---------- Integrations (optional) ----------
SLACK_BOT_TOKEN=
PAGERDUTY_API_KEY=
JIRA_API_KEY=
GOOGLE_CALENDAR_KEY=

# ---------- CORS ----------
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------- Seeding (optional) ----------
# Password used when running seed scripts to create test users
SEED_PASSWORD=

# ---------- Environment ----------
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- JWT (for custom auth) ----------
# [REQUIRED] JWT signing secret for authentication tokens (minimum 32 characters)
# SECURITY CRITICAL: Generate a cryptographically secure random secret
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER use default values or commit this to version control
JWT_SECRET=

# ---------- SSO - Google OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ALLOWED_DOMAINS=

# ---------- SSO - Azure AD ----------
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# ---------- SSO - SAML ----------
SAML_ENTITY_ID=
SAML_SSO_URL=
SAML_CERTIFICATE=

# ---------- Demo Credentials ----------
# admin@sentinel.demo / Admin123!
# sarah.kim@sentinel.demo / Manager123!
# jordan.smith@sentinel.demo / Manager123!
