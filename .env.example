# ============================================================
# Sentinel Backend -- Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] will prevent the app from starting if missing.
# Variables marked [OPTIONAL] have sensible defaults and can be left empty.
#
# NEVER commit your .env file to version control.
# ============================================================

# ---------- Database [REQUIRED] ----------
# PostgreSQL connection string.
# For Supabase: Settings > Database > Connection string (Session mode)
# For local: postgresql://postgres:password@localhost:5432/sentinel
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ---------- Supabase [REQUIRED] ----------
# Project URL and keys from Supabase > Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ---------- Security [REQUIRED] ----------
# Random salt for HMAC-SHA256 identity hashing (min 8 characters).
# Any cryptographically secure random string. Example:
#   python -c "import secrets; print(secrets.token_hex(32))"
VAULT_SALT=generate-a-random-string-here-min-8-chars

# Fernet encryption key for PII encryption (44-char base64 string).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate-a-fernet-key-here

# ---------- JWT [REQUIRED] ----------
# JWT signing secret for authentication tokens (minimum 32 characters).
# SECURITY CRITICAL: Generate a cryptographically secure random secret.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# NEVER use default values like "secret" or "change-me-in-production".
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- LLM / AI [REQUIRED: at least GEMINI_API_KEY] ----------
# Google Gemini API key for AI chat, intent classification, and sentiment analysis.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [OPTIONAL] Alternative LLM API key for direct calls (e.g., Groq)
LLM_API_KEY=

# [OPTIONAL] Primary and fallback model names
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODEL=gemini-2.0-flash-lite

# ---------- Portkey AI Gateway [OPTIONAL] ----------
# For LLM routing, fallback, and observability.
# Sign up at: https://portkey.ai
PORTKEY_API_KEY=
PORTKEY_VIRTUAL_KEY=
PORTKEY_FALLBACK_VIRTUAL_KEY=

# ---------- Composio Integration [OPTIONAL] ----------
# Enables external tool integrations (GitHub, Slack, Calendar, Gmail) via MCP.
# Sign up at: https://composio.dev
COMPOSIO_API_KEY=

# ---------- Slack [OPTIONAL] ----------
# Direct Slack bot token (for nudge dispatch without Composio)
SLACK_BOT_TOKEN=

# ---------- Context API Keys [OPTIONAL] ----------
# Used by the Context Enricher to filter "explained" late-night work
PAGERDUTY_API_KEY=
JIRA_API_KEY=
GOOGLE_CALENDAR_KEY=

# Legacy key (unused, kept for compatibility)
OPENAI_API_KEY=

# ---------- Redis [OPTIONAL] ----------
# Falls back to in-memory if unavailable.
# Local: redis://localhost:6379/0
# Upstash: rediss://default:your-password@your-endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ---------- MCP Session Cache [OPTIONAL] ----------
MCP_SESSION_TTL_SECONDS=1800
MCP_LOCK_TIMEOUT_SECONDS=30

# ---------- CORS [OPTIONAL] ----------
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------- App Settings [OPTIONAL] ----------
SIMULATION_MODE=True
DATA_RETENTION_DAYS=90
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- Rate Limiting [OPTIONAL] ----------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ---------- Seeding [OPTIONAL] ----------
# Password assigned to demo users when running seed scripts
SEED_PASSWORD=Demo123!

# ---------- SSO - Google OAuth [OPTIONAL] ----------
# Set up at: https://console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ALLOWED_DOMAINS=

# ---------- SSO - Azure AD [OPTIONAL] ----------
# Set up at: https://portal.azure.com > App registrations
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# ---------- SSO - SAML [OPTIONAL] ----------
SAML_ENTITY_ID=
SAML_SSO_URL=
SAML_CERTIFICATE=
