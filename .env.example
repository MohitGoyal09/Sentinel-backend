# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase PostgreSQL Connection String (for SQLAlchemy)
# Format: postgresql://[user]:[password]@[host]:[port]/[default_db]
# Note: Ensure you use the 'pooler' connection string (usually port 6543) if available, or direct (5432).
# Get this from: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Security Keys
# VAULT_SALT: Used for identity hashing interactions (Privacy Vault)
# ENCRYPTION_KEY: 32-byte URL-safe base64-encoded key for Fernet encryption
VAULT_SALT=CHANGE_THIS_TO_RANDOM_SALT_STRING
ENCRYPTION_KEY=CHANGE_THIS_TO_VALID_FERNET_KEY # e.g. generated via Fernet.generate_key()

# External Integrations (Optional for now)
OPENAI_API_KEY=
SLACK_BOT_TOKEN=
